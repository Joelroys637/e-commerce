<%- include('../partials/header.ejs', { pageTitle: 'Update Product' }) %>

    <div class="admin-layout" style="margin-top: 2rem;">
        <%- include('../partials/admin-sidebar.ejs') %>

            <div class="admin-content">
                <h2 style="margin-bottom: 2rem;">Update Product</h2>

                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert alert-danger">
                        <%= error %>
                    </div>
                    <% } %>

                        <form action="/admin/update-product/<%= product.productId %>" method="POST"
                            enctype="multipart/form-data" style="max-width: 600px;">
                            <div class="form-group">
                                <label for="name">Product Name</label>
                                <input type="text" id="name" name="name" class="form-control"
                                    value="<%= product.name %>" required>
                            </div>

                            <div style="display: flex; gap: 1rem;">
                                <div class="form-group" style="flex: 1;">
                                    <label for="price">Price (₹)</label>
                                    <input type="number" id="price" name="price" class="form-control"
                                        value="<%= product.price %>" required min="0" step="0.01">
                                </div>

                                <div class="form-group" style="flex: 1;">
                                    <label for="offer">Offer Percentage (%)</label>
                                    <input type="number" id="offer" name="offer" class="form-control"
                                        value="<%= product.offer %>" min="0" max="100">
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="category">Category</label>
                                <!-- For simplicity, use text input or re-populate select with JS/server logic. Let's do a simple text input or predefined structure -->
                                <input type="text" id="category" name="category" class="form-control"
                                    value="<%= product.category %>" required>
                            </div>

                            <div class="form-group">
                                <label for="productImage">Replace Image (Optional, leave blank to keep current)</label>
                                <div style="margin-bottom: 1rem;">
                                    <img src="<%= product.uploadimage %>" alt="Current Image"
                                        style="height: 100px; border-radius: 8px;">
                                </div>
                                <input type="file" id="productImage" name="productImage" class="form-control"
                                    accept="image/png, image/jpeg, image/jpg">
                            </div>

                            <div class="form-group">
                                <label for="description">Detailed Description</label>
                                <textarea id="description" name="description" class="form-control" rows="5"
                                    required><%= product.description %></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary" style="color: white; width: 100%;">Save
                                Changes</button>
                        </form>
            </div>
    </div>

    <%- include('../partials/footer.ejs') %>