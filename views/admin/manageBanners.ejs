<%- include('../partials/header.ejs', { pageTitle: 'Manage Banners' }) %>

    <div class="admin-layout" style="margin-top: 2rem;">
        <%- include('../partials/admin-sidebar.ejs') %>

            <div class="admin-content">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                    <h2>Manage Banners</h2>
                    <a href="/admin/add-banner" class="btn btn-primary" style="color: white;">+ Add New Banner</a>
                </div>

                <% if (banners.length===0) { %>
                    <p>No banners found. Add a new banner to display it on the home page.</p>
                <% } else { %>
                    <table>
                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% banners.forEach(banner=> { %>
                                <tr>
                                    <td>
                                        <img src="<%= banner.uploadimage %>" alt="Banner" style="width: 100px; height: 50px; object-fit: cover; border-radius: 5px;">
                                    </td>
                                    <td>
                                        <%= banner.title %>
                                    </td>
                                    <td>
                                        <%= banner.category %>
                                    </td>
                                    <td>
                                        <form action="/admin/delete-banner/<%= banner.bannerId %>" method="POST"
                                            style="display: inline;">
                                            <button type="submit" class="btn btn-danger"
                                                onclick="return confirm('Are you sure you want to delete this banner?')">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>
            </div>
    </div>

    <%- include('../partials/footer.ejs') %>
