<%- include('../partials/header.ejs', { pageTitle: 'Add Product' }) %>

    <div class="admin-layout" style="margin-top: 2rem;">
        <%- include('../partials/admin-sidebar.ejs') %>

            <div class="admin-content">
                <h2 style="margin-bottom: 2rem;">Add New Product</h2>

                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert alert-danger">
                        <%= error %>
                    </div>
                    <% } %>

                        <form action="/admin/add-product" method="POST" enctype="multipart/form-data"
                            style="max-width: 600px;">
                            <div class="form-group">
                                <label for="name">Product Name</label>
                                <input type="text" id="name" name="name" class="form-control" required
                                    placeholder="e.g. Nike Air Max">
                            </div>

                            <div style="display: flex; gap: 1rem;">
                                <div class="form-group" style="flex: 1;">
                                    <label for="price">Price (₹)</label>
                                    <input type="number" id="price" name="price" class="form-control" required min="0"
                                        step="0.01">
                                </div>

                                <div class="form-group" style="flex: 1;">
                                    <label for="offer">Offer Percentage (%)</label>
                                    <input type="number" id="offer" name="offer" class="form-control" value="0" min="0"
                                        max="100">
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="category">Category</label>
                                <select id="category" name="category" class="form-control" required>
                                    <option value="Electronics">Electronics</option>
                                    <option value="Fashion">Fashion</option>
                                    <option value="Home">Home & Kitchen</option>
                                    <option value="Beauty">Beauty</option>
                                    <option value="Sports">Sports</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="productImage">Product Image Upload *Less then 1MB(PNG, JPG)</label>
                                <input type="file" id="productImage" name="productImage" class="form-control"
                                    accept="image/png, image/jpeg, image/jpg" required>
                            </div>

                            <div class="form-group">
                                <label for="description">Detailed Description</label>
                                <textarea id="description" name="description" class="form-control" rows="5" required
                                    placeholder="Describe the product..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary" style="color: white; width: 100%;">Create
                                Product</button>
                        </form>
            </div>
    </div>

    <%- include('../partials/footer.ejs') %>