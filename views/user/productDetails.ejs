<%- include('../partials/header.ejs', { pageTitle: product.name }) %>

    <div class="detail-container">
        <div class="detail-img">
            <div class="image-gallery" style="display: flex; overflow-x: auto; gap: 1rem; scroll-snap-type: x mandatory; scrollbar-width: none; padding-bottom: 0.5rem;">
                <img src="<%= product.uploadimage %>" alt="<%= product.name %>" style="flex: 0 0 100%; scroll-snap-align: start;">
                <img src="<%= product.uploadimage %>" alt="<%= product.name %> - View 2" style="flex: 0 0 100%; scroll-snap-align: start;">
                <img src="<%= product.uploadimage %>" alt="<%= product.name %> - View 3" style="flex: 0 0 100%; scroll-snap-align: start;">
            </div>
            <style>
                .image-gallery::-webkit-scrollbar { display: none; }
            </style>
            
            <!-- Thumbnail Images (Mobile) -->
            <div class="mobile-thumbnails">
                <div style="width: 80px; height: 80px; border-radius: 8px; border: 2px solid var(--primary); overflow: hidden; cursor: pointer; box-shadow: var(--shadow-sm);">
                    <img src="<%= product.uploadimage %>" style="width: 100%; height: 100%; object-fit: cover;" alt="<%= product.name %> view 1">
                </div>
                <div style="width: 80px; height: 80px; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden; cursor: pointer; opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
                    <img src="<%= product.uploadimage %>" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.9);" alt="<%= product.name %> view 2">
                </div>
                <div style="width: 80px; height: 80px; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden; cursor: pointer; opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
                    <img src="<%= product.uploadimage %>" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.9);" alt="<%= product.name %> view 3">
                </div>
            </div>
        </div>
        <div class="detail-info">
            <span style="color: var(--primary); font-weight: bold; text-transform: uppercase;">
                <%= product.category %>
            </span>
            <h1>
                <%= product.name %>
            </h1>

            <div style="display: flex; gap: 1rem; align-items: baseline; margin-bottom: 2rem;">
                <span id="display-price" style="font-size: 2.5rem; font-weight: 700;">₹<%= product.price %></span>
                <% if (product.offer> 0) { %>
                    <span
                        style="color: #16a34a; font-weight: bold; font-size: 1.2rem; background: #dcfce7; padding: 0.3rem 0.8rem; border-radius: 6px;">
                        <%= product.offer %>% OFF
                    </span>
                    <% } %>
            </div>

            <p>
                <%= product.description %>
            </p>

            <!-- Thumbnail Images (Desktop) -->
            <div class="desktop-thumbnails">
                <div style="width: 80px; height: 80px; border-radius: 8px; border: 2px solid var(--primary); overflow: hidden; cursor: pointer; box-shadow: var(--shadow-sm);">
                    <img src="<%= product.uploadimage %>" style="width: 100%; height: 100%; object-fit: cover;" alt="<%= product.name %> view 1">
                </div>
                <div style="width: 80px; height: 80px; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden; cursor: pointer; opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
                    <img src="<%= product.uploadimage %>" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.9);" alt="<%= product.name %> view 2">
                </div>
                <div style="width: 80px; height: 80px; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden; cursor: pointer; opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
                    <img src="<%= product.uploadimage %>" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.9);" alt="<%= product.name %> view 3">
                </div>
            </div>

            <!-- Order Form -->
            <div style="margin-top: auto; padding-top: 2rem; border-top: 1px solid #e5e7eb;">
                <form action="/place-order" method="POST" id="order-form" style="display: flex; gap: 1rem; flex-wrap: wrap;">
                    <input type="hidden" id="productId" name="productId" value="<%= product.productId %>">
                    <input type="hidden" id="productName" value="<%= product.name %>">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <label style="font-weight: 600;">Qty:</label>
                        <div style="display: flex; align-items: center; border: 1px solid #ccc; border-radius: 8px; overflow: hidden;">
                            <button type="button" onclick="changeQty(-1)" style="padding: 0.5rem 1rem; background: #f3f4f6; border: none; cursor: pointer; font-weight: bold; border-right: 1px solid #ccc;">-</button>
                            <input type="number" id="qty" name="quantity" value="1" min="1" max="10" readonly
                                style="width: 50px; text-align: center; border: none; outline: none; padding: 0.5rem 0;">
                            <button type="button" onclick="changeQty(1)" style="padding: 0.5rem 1rem; background: #f3f4f6; border: none; cursor: pointer; font-weight: bold; border-left: 1px solid #ccc;">+</button>
                        </div>
                    </div>
                    <div style="display: flex; gap: 1rem; flex-grow: 1; flex-wrap: wrap;">
                        <button type="button" onclick="addToCart()" class="btn"
                            style="flex-grow: 1; padding: 1rem; font-size: 1.1rem; border-radius: 8px; box-shadow: var(--shadow-sm); border: 2px solid var(--primary); color: var(--primary); font-weight: bold; background: white;">
                            🛒 Add to Cart
                        </button>
                        <button type="submit" class="btn btn-primary"
                            style="flex-grow: 1; color: white; padding: 1rem; font-size: 1.1rem; border-radius: 8px; box-shadow: var(--shadow-lg);">
                            🛍️ Place Order (COD)
                        </button>
                        <button type="button" id="pay-online-btn" class="btn"
                            style="flex-grow: 1; background: #1e3a8a; color: white; padding: 1rem; font-size: 1.1rem; border-radius: 8px; box-shadow: var(--shadow-lg); font-weight: 600;">
                            💳 Pay Online
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Razorpay Integration and Qty Control Script -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        const basePrice = Number("<%= product.price %>");

        function changeQty(amount) {
            const qtyInput = document.getElementById('qty');
            let currentVal = parseInt(qtyInput.value);
            if (isNaN(currentVal)) currentVal = 1;
            let newVal = currentVal + amount;
            if (newVal >= 1 && newVal <= 10) {
                qtyInput.value = newVal;
                // Dynamically update the price displayed on the page
                document.getElementById('display-price').innerText = '₹' + (basePrice * newVal);
            }
        }

        async function addToCart() {
            const productId = document.getElementById('productId').value;
            const quantity = document.getElementById('qty').value;
            
            try {
                const res = await fetch('/api/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, quantity })
                });
                if (res.status === 401) {
                    window.location.href = '/auth/login';
                    return;
                }
                const data = await res.json();
                if (res.ok) {
                    showToast('Added to cart successfully!');
                } else {
                    showToast('Error adding to cart.', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('Something went wrong.', 'error');
            }
        }

        document.getElementById('pay-online-btn').addEventListener('click', async () => {
            const productId = document.getElementById('productId').value;
            const quantity = document.getElementById('qty').value;
            const productName = document.getElementById('productName').value;

            try {
                const response = await fetch('/create-razorpay-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, quantity })
                });

                if(response.redirected) {
                    window.location.href = response.url;
                    return;
                }

                const data = await response.json();
                if(data.error) {
                    showToast('Error: ' + data.error, 'error');
                    return;
                }

                const options = {
                    key: data.key_id,
                    amount: data.order.amount,
                    currency: "INR",
                    name: "Joelx Orbit",
                    description: "Purchase " + productName,
                    order_id: data.order.id,
                    handler: async function (response) {
                        const verifyRes = await fetch('/verify-payment', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_signature: response.razorpay_signature,
                                productId,
                                quantity
                            })
                        });
                        const verifyData = await verifyRes.json();
                        if(verifyData.success) {
                            window.location.href = verifyData.redirectUrl;
                        } else {
                            showToast("Payment verification failed. Please contact support.", "error");
                        }
                    },
                    theme: { color: "#2563eb" }
                };

                const rzp = new Razorpay(options);
                rzp.open();

            } catch (error) {
                console.error(error);
                showToast('Something went wrong. Please try again.', 'error');
            }
        });
    </script>

    <%- include('../partials/footer.ejs') %>