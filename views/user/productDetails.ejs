<%- include('../partials/header.ejs', { pageTitle: product.name }) %>

    <div class="detail-container">
        <div class="detail-img">
            <img src="<%= product.uploadimage %>" alt="<%= product.name %>">
        </div>
        <div class="detail-info">
            <span style="color: var(--primary); font-weight: bold; text-transform: uppercase;">
                <%= product.category %>
            </span>
            <h1>
                <%= product.name %>
            </h1>

            <div style="display: flex; gap: 1rem; align-items: baseline; margin-bottom: 2rem;">
                <span style="font-size: 2.5rem; font-weight: 700;">₹<%= product.price %></span>
                <% if (product.offer> 0) { %>
                    <span
                        style="color: #16a34a; font-weight: bold; font-size: 1.2rem; background: #dcfce7; padding: 0.3rem 0.8rem; border-radius: 6px;">
                        <%= product.offer %>% OFF
                    </span>
                    <% } %>
            </div>

            <p>
                <%= product.description %>
            </p>

            <!-- Order Form -->
            <div style="margin-top: auto; padding-top: 2rem; border-top: 1px solid #e5e7eb;">
                <form action="/place-order" method="POST" style="display: flex; gap: 1rem; flex-wrap: wrap;">
                    <input type="hidden" name="productId" value="<%= product.productId %>">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <label for="qty" style="font-weight: 600;">Qty:</label>
                        <input type="number" id="qty" name="quantity" value="1" min="1" max="10" class="form-control"
                            style="width: 80px;">
                    </div>
                    <button type="submit" class="btn btn-primary"
                        style="flex-grow: 1; color: white; padding: 1rem; font-size: 1.1rem; border-radius: 8px; box-shadow: var(--shadow-lg);">
                        🛍️ Place Order (Cash on Delivery)
                    </button>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/footer.ejs') %>