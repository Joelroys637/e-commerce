<%- include('../partials/header.ejs', { pageTitle: 'My Orders' }) %>

    <h2 style="margin-top: 2rem; border-left: 4px solid var(--primary); padding-left: 1rem;">My Orders</h2>

    <div
        style="background: white; border-radius: var(--border-radius); box-shadow: var(--shadow); padding: 1.5rem; margin-top: 2rem;">
        <% if (orders.length===0) { %>
            <p>You haven't placed any orders yet.</p>
            <a href="/products" class="btn btn-primary" style="margin-top: 1rem; color: white;">Shop Now</a>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Product Name</th>
                            <th>Qty</th>
                            <th>Total Cost</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order=> { %>
                            <tr>
                                <td style="font-family: monospace; font-size: 0.9rem; color: var(--text-muted);">
                                    <%= order.orderId.substring(1, 9) %>...
                                </td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                        <% if(order.productDetail) { %>
                                            <img src="<%= order.productDetail.uploadimage %>"
                                                alt="<%= order.productDetail.name %>"
                                                style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;">
                                            <span>
                                                <%= order.productDetail.name %>
                                            </span>
                                            <% } else { %>
                                                <span>Product Unavailable</span>
                                                <% } %>
                                    </div>
                                </td>
                                <td>
                                    <%= order.quantity %>
                                </td>
                                <td style="font-weight: 600;">
                                    <% if(order.productDetail) { %>
                                        ₹<%= order.productDetail.price * order.quantity %>
                                            <% } else { %>
                                                -
                                                <% } %>
                                </td>
                                <td>
                                    <span
                                        style="background: #fef9c3; color: #854d0e; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem; font-weight: 600;">
                                        <%= order.orderStatus %>
                                    </span>
                                </td>
                                <td>
                                    <%= new Date(order.timestamp).toLocaleDateString() %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
                <% } %>
    </div>

    <%- include('../partials/footer.ejs') %>